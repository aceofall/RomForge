<UserControl x:Class="NSW.WPF.UI.FileManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:l="clr-namespace:NSW.Core.Properties;assembly=NSW.Core"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">

    <UserControl.Resources>
        
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </UserControl.Resources>

    <Border BorderBrush="#33FFFFFF" 
            BorderThickness="1" 
            CornerRadius="8" 
            Background="#12FFFFFF" 
            Padding="10">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel x:Name="dropHint"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Opacity="0.80"
                        IsHitTestVisible="False"
                        Panel.ZIndex="1">
                    <Image Source="/Assets/Images/Drag.png" Width="28" Height="28" Margin="0,0,0,8"/>
                    <TextBlock Text="파일 또는 폴더를 여기에 드래그&amp;드롭하세요" Foreground="LightGray" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <ItemsControl HorizontalAlignment="Center" Margin="0,5,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Items>
                            <Border Background="#1A4D56B2" BorderBrush="#4D4D56B2" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                <TextBlock Text="NSP" Foreground="#8FA3FF" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#8FA3FF" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Border>
                            <Border Background="#1A9E5B24" BorderBrush="#559E5B24" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                <TextBlock Text="NSZ" Foreground="#FFA254" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#FFA254" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Border>
                            <Border Background="#1A9E2469" BorderBrush="#559E2469" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                <TextBlock Text="XCI" Foreground="#FF73C9" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#FF73C9" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Border>
                            <Border Background="#1A1B8A5A" BorderBrush="#551B8A5A" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                <TextBlock Text="XCZ" Foreground="#54FFB5" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#54FFB5" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Border>
                        </ItemsControl.Items>
                    </ItemsControl>
                </StackPanel>

                <ListView x:Name="lvFiles" AllowDrop="True" DragEnter="LvFiles_DragEnter" Drop="LvFiles_Drop" KeyUp="LvFiles_KeyUp" SelectionMode="Extended" ContextMenuOpening="LvFiles_ContextMenuOpening">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="폴더 열기" Click="MenuItem_OpenFolder_Click">
                                <MenuItem.Icon>
                                    <Image Source="/Assets/Images/AddFolder.png" Width="20" Height="20"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="선택 삭제" Click="BtnRemoveFile_Click">
                                <MenuItem.Icon>
                                    <Image Source="/Assets/Images/Delete.png" Width="20" Height="20"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="전체 삭제" Click="BtnRemoveAllFiles_Click">
                                <MenuItem.Icon>
                                    <Image Source="/Assets/Images/Clear.png" Width="20" Height="20"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="70">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{x:Static l:Resources.Header_Type}" Foreground="#BBBBBB" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding TypeBackground}" CornerRadius="4" Padding="8,3" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2,0">
                                            <TextBlock Text="{Binding FileType}" Foreground="{Binding TypeForeground}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="타이틀" Width="380">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,5">
                                            <Border Width="36" Height="36" CornerRadius="6" Margin="0,0,12,0">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TitleName}" FontWeight="Bold" FontSize="12" ToolTip="{Binding FilePath}"/>
                                                <TextBlock Text="{Binding TitleID}" FontSize="10" Foreground="Gray"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="버전" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="5,2">
                                            <TextBlock Text="{Binding Version}" FontWeight="Bold" FontSize="12" ToolTip="{Binding Version}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Width="70">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{x:Static l:Resources.Header_Ext}" Foreground="#BBBBBB" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding ExtensionBackground}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2,0">
                                            <TextBlock Text="{Binding Extension}" Foreground="{Binding ExtensionForeground}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{x:Static l:Resources.Header_Size}" Width="75">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileSize}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                <Button x:Name="btnAddFile" Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" ToolTip="{x:Static l:Resources.ToolTip_AddFile}" Style="{StaticResource GrayButton}" Click="BtnAddFile_Click">
                    <Image Source="/Assets/Images/AddFile.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
                <Button x:Name="btnAddFolder" Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" ToolTip="폴더 추가" Style="{StaticResource GrayButton}" Click="BtnAddFolder_Click">
                    <Image Source="/Assets/Images/AddFolder.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
                <Button x:Name="btnRemoveFile" Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" ToolTip="{x:Static l:Resources.ToolTip_RemoveSelected}" Style="{StaticResource GrayButton}" Click="BtnRemoveFile_Click">
                    <Image Source="/Assets/Images/Delete.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
                <Button x:Name="btnRemoveAllFiles" Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" ToolTip="{x:Static l:Resources.ToolTip_RemoveAll}" Style="{StaticResource GrayButton}" Click="BtnRemoveAllFiles_Click">
                    <Image Source="/Assets/Images/Clear.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
                <Button x:Name="btnExtra1" Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" Visibility="Collapsed" ToolTip="Extra" Style="{StaticResource GrayButton}" Click="BtnExtra1_Click"/>
                <Button x:Name="btnExtra2" Width="30" Height="30" Padding="0" BorderThickness="1" Visibility="Collapsed" ToolTip="Extra" Style="{StaticResource GrayButton}" Click="BtnExtra2_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>