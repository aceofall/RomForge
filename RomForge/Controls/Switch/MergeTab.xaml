<UserControl x:Class="RomForge.Controls.Switch.MergeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:core="clr-namespace:NSW.WPF.UI;assembly=NSW.WPF"
             xmlns:l="clr-namespace:NSW.Core.Properties;assembly=NSW.Core"             
             xmlns:local="clr-namespace:RomForge.Controls.Switch"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: File Manager -->
            <core:FileManagerControl x:Name="fileMgr" Grid.Row="0" Margin="0,0,0,5" IsEnabled="{Binding IsIdle}"/>

            <!-- Row 1: Output Path -->
            <Grid Grid.Row="1" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Workspace Button -->
                <Button Grid.Column="0" x:Name="btnWorkSpace" Width="36" Height="36" Padding="0" Margin="5,0,0,0" Background="Transparent" BorderThickness="0" Command="{Binding OpenWorkSpaceCommand}" IsEnabled="{Binding IsIdle}">
                    <Button.ToolTip>
                        <ToolTip Content="{x:Static l:Resources.ToolTip_OpenWorkSpace}"/>
                    </Button.ToolTip>
                    <Image Source="/Assets/Images/WorkSpace.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <!-- Output Label -->
                <TextBlock Grid.Column="1" Text="{x:Static l:Resources.Label_OutputPath}" FontSize="12" Margin="10,0,10,0" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>

                <!-- Output TextBox -->
                <Border Grid.Column="2" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6">
                    <TextBox x:Name="txtOutput" FontSize="11" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" VerticalContentAlignment="Center" Text="{Binding OutputPath, Mode=TwoWay}" Height="36" IsEnabled="{Binding IsIdle}">
                    </TextBox>
                </Border>

                <!-- Browse Button -->
                <Button Grid.Column="3" x:Name="btnBrowseOutput" Width="36" Height="36" Padding="0" Margin="5,0,5,0" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="BtnBrowseOutput_Click" IsEnabled="{Binding IsIdle}">
                    <Button.ToolTip>
                        <ToolTip Content="{x:Static l:Resources.ToolTip_BrowseOutput}"/>
                    </Button.ToolTip>
                    <Image Source="/Assets/Images/OpenFolder.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
            </Grid>

            <!-- Row 2: Action Buttons -->
            <Grid Grid.Row="2" Margin="5,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Merge Button -->
                <core:IconButton Grid.Column="0"
                               x:Name="btnMergeStart"
                               DefaultText="{x:Static l:Resources.Button_MergeStart}"
                               DefaultIcon="/Assets/Images/Merge.png"
                               CancelText="{x:Static l:Resources.Button_Cancel}"
                               CancelIcon="/Assets/Images/Cancel.png"
                               IsRunning="{Binding IsMergeRunning}" IsEnabled="{Binding MergeEnabled}"
                               Click="BtnMergeStart_Click"/>

                <!-- Split Button -->
                <core:IconButton Grid.Column="2"
                               x:Name="btnSplitStart" Margin="0,0,5,0"
                               DefaultText="{x:Static l:Resources.Button_SplitStart}"
                               DefaultIcon="/Assets/Images/Split.png"
                               CancelText="{x:Static l:Resources.Button_Cancel}"
                               CancelIcon="/Assets/Images/Cancel.png"
                               IsRunning="{Binding IsSplitRunning}" IsEnabled="{Binding SplitEnabled}"
                               Click="BtnSplitStart_Click"/>
            </Grid>

            <!-- Row 3: Progress Area -->
            <Grid Grid.Row="3" Margin="5,0,5,5" x:Name="progressArea"
              Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="5,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" x:Name="progressLabel"
                           Text="{Binding ProgressLabel}"
                           FontSize="11" Foreground="#A0A0A0" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1" x:Name="progressPercent"
                           Text="{Binding ProgressPercent}"
                           Margin="10,0,15,0" FontSize="11" Foreground="#4CAF50" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="progressSpeed"
                               Text="{Binding ProgressSpeed}"
                               Foreground="Gray" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="progressTime"
                               Text="{Binding ProgressTime}"
                               FontSize="11" Foreground="#4CAF50" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <ProgressBar Grid.Row="1" x:Name="progress"
                         Value="{Binding ProgressPct}"
                         Minimum="0" Maximum="100" Height="4"/>
            </Grid>


        </Grid>
    </Grid>

</UserControl>
