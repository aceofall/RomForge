<UserControl x:Class="RomForge.Controls.Util.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.expression/blend/2008" 
             xmlns:local="clr-namespace:RomForge.Controls.Util"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid>
        <TabControl SelectedIndex="{Binding SubTabIndex, Mode=TwoWay}"
                    IsEnabled="{Binding IsIdle}"
                    Background="Transparent" 
                    BorderThickness="0">

            <TabItem Header="ZipImageTool">
                <local:ZipImageToolTab DataContext="{Binding ZipImageToolVM}"/>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>