<UserControl x:Class="RomForge.Controls.Util.ZipImageToolTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="이동식 드라이브:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding UsbDrives}" 
                      SelectedItem="{Binding SelectedUsbDrive}"
                      IsEnabled="{Binding IsIdle}"
                      Height="32" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="새로고침" 
                    Command="{Binding RefreshDrivesCommand}" 
                    IsEnabled="{Binding IsIdle}"
                    Margin="10,0,0,0" Padding="15,0" Height="32"/>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="1" BorderBrush="#CCCCCC">
            <TabItem Header="굽기" Height="35" Width="100" FontSize="13">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding WriteImagePath, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="32" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="열기" Command="{Binding OpenWriteImageCommand}" 
                                IsEnabled="{Binding IsIdle}" Width="90" Height="32"/>
                    </Grid>

                    <Button Grid.Row="2" HorizontalAlignment="Right" Width="130" Height="42"
                            Command="{Binding WriteCommand}" FontSize="14" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="굽기"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWorking}" Value="True">
                                        <Setter Property="Content" Value="취소"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </TabItem>

            <TabItem Header="저장" Height="35" Width="100" FontSize="13">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ReadImagePath, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="32" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="열기" Command="{Binding OpenReadImageCommand}" 
                                IsEnabled="{Binding IsIdle}" Width="90" Height="32"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Visibility="{Binding IsZipOptionsVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="최대 분할 크기:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding SegmentSizes}" 
                                      SelectedIndex="{Binding SelectedSegmentIndex}" 
                                      IsEnabled="{Binding IsIdle}" Height="30" VerticalContentAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="압축 레벨:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding CompressionLevels}" 
                                      SelectedIndex="{Binding SelectedCompressionIndex}" 
                                      IsEnabled="{Binding IsIdle}" Height="30" VerticalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <Button Grid.Row="3" HorizontalAlignment="Right" Width="130" Height="42"
                            Command="{Binding ReadCommand}" FontSize="14" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="저장"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWorking}" Value="True">
                                        <Setter Property="Content" Value="취소"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusMessage1}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage2}" VerticalAlignment="Center" Margin="15,0"/>
            <ProgressBar Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="22"/>
        </Grid>
    </Grid>
</UserControl>